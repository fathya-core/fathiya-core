        "responseBody": "={{ JSON.stringify({ accepted: $json.accepted, status: $json.status, task_id: $json.task_id, profile: $json.profile, receipt_id: $json.receipt_id, dispatch_allowed: $json.dispatch_allowed, error: $json.error }) }}",
        "options": {
          "responseCode": "={{ $json.status === 'rejected' ? 400 : 202 }}"
        }
      },
