            {
              "name": "X-FATHIYA-Bridge-Token",
              "value": "={{ $env.FATHIYA_CONNECTOR_DISPATCH_TOKEN }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
