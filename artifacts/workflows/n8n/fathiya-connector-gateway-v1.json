{
  "id": "FathiyaConnectorGatewayV1",
  "name": "FATHIYA Connector Gateway v1",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "fathiya-agent-bridge-v1",
        "responseMode": "responseNode",
        "options": {
          "ipWhitelist": "127.0.0.1,::1"
        }
      },
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
      "position": [
        -640,
        0
      ],
      "id": "b5779d47-1a5d-41be-a7bd-37644e9e8b13",
      "name": "Local FATHIYA Ingress",
      "webhookId": "1fd8db5a-578a-4e86-9011-280e244cd0ab"
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst body = input.body ?? input;\nconst allowedProfiles = new Set([\n  'n8n_health',\n  'n8n_workflows',\n  'zapier_fathiya_webhook',\n  'cursor_agent_bridge',\n  'manus_agent_bridge',\n]);\nconst taskId = String(body.task_id ?? '').trim();\nconst profile = String(body.profile ?? '').trim();\nconst approvalState = String(body.approval_state ?? 'pending').trim();\nconst valid = Boolean(taskId) && allowedProfiles.has(profile);\nconst dispatchAllowed = valid && approvalState === 'approved';\nreturn [{\n  json: {\n    accepted: valid,\n    status: valid ? (dispatchAllowed ? 'approved_for_dispatch' : 'awaiting_approval') : 'rejected',\n    task_id: taskId || null,\n    profile: profile || null,\n    approval_state: approvalState,\n    dispatch_allowed: dispatchAllowed,\n    payload: body.payload && typeof body.payload === 'object' ? body.payload : {},\n    query: body.query && typeof body.query === 'object' ? body.query : {},\n    receipt_id: `N8N-STAGE-${Date.now()}-${(taskId || 'invalid').slice(0, 8)}`,\n    source: 'fathiya-agent-runtime',\n    error: valid ? null : 'task_id and an allowed connector profile are required',\n  },\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -400,
        0
      ],
      "id": "79a75152-784d-453e-922b-d0c79c8f9dd8",
      "name": "Validate and Gate"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 2
          },
          "conditions": [
            {
              "id": "a0a45936-345a-4374-83ad-704834fcf08d",
              "leftValue": "={{ $json.dispatch_allowed }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        -160,
        0
      ],
      "id": "076e3910-977c-4f8c-92e0-65b890e2f545",
      "name": "Approval Granted?"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.FATHIYA_CONNECTOR_DISPATCH_URL }}",
        "sendHeaders": true,
        "headerParameters": {
