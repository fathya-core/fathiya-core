        "type": "DOMAIN",
        "value": "google.com"
      },
      "expected_status": "PENDING_ANALYSIS",
      "fail_conditions": [
        "فشل استخلاص النوع كـDOMAIN",
        "لم يتم توجيه المدخل للتحليل الكامل"
      ],
      "notes": "حالة اختبار أساسية لنطاق معروف وصحيح."
    },
    {
