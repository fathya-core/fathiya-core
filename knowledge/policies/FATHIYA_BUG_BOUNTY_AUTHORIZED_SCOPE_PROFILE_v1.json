  "purpose": "Define the evidence FATHIYA must have before moving a bug bounty task from learning/planning to non-loopback live testing.",
  "operator_boundary_mode": "pending_operator_definition",
  "default_mode": "planning_and_local_lab_only_until_target_scope_record_exists",
  "scope_record_required_fields": [
    "program_name",
    "platform",
    "program_policy_url_or_uploaded_text",
    "target_asset",
    "asset_type",
    "in_scope_statement",
    "out_of_scope_statement",
    "allowed_test_types",
    "disallowed_test_types",
    "rate_limit_or_noise_limit",
    "test_accounts_available",
    "reporting_channel",
    "operator_scope_confirmation_timestamp"
  ],
  "allowed_without_scope_record": [
    "study_official_sources",
    "study_local_corpus",
    "write_target_scope_request",
    "write_passive_recon_plan",
    "analyze_user_provided_evidence",
    "draft_report_from_user_provided_evidence",
    "run_loopback_lab_targets",
    "run_local_json_markdown_validation",
    "run_comprehension_evals"
  ],
  "requires_scope_record": [
    "non_loopback_active_scanning",
    "hexstrike_lab_scan_against_non_loopback_target",
