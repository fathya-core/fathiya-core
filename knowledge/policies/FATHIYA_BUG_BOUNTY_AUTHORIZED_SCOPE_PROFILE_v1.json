  },
  "receipt_requirements": [
    "scope_record_id_or_scope_missing_reason",
    "selected_learning_card_ids",
    "selected_eval_ids",
    "target_classification",
    "allowed_next_action",
    "tools_used",
    "manual_validation_status",
    "report_path_or_reason_not_report_ready"
