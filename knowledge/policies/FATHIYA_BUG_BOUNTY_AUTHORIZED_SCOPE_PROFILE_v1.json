    "burp_automation_against_public_target",
    "fuzzing_or_content_discovery",
    "authenticated_testing_on_third_party_program",
    "callback_based_ssrf_validation_against_live_program",
    "rate_sensitive_tests"
  ],
  "requires_separate_operator_approval_even_with_scope": [
    "destructive_or_state_changing_tests",
    "credential_or_token_exposure_handling",
    "tests_that_access_third_party_user_data",
    "high_rate_or_disruptive_scans",
    "social_engineering",
    "phishing",
    "denial_of_service",
    "payment_or_financial_flow_testing",
    "real_trade_or_real_money_actions"
  ],
  "tool_profiles": {
    "loopback_lab": {
      "target_patterns": [
        "127.0.0.1",
        "localhost",
        "::1"
      ],
      "tools": [
        "hexstrike_lab_scan",
        "kali_tool_inventory",
        "security_core_plan",
        "knowledge_search"
      ],
      "approval": "operator_requested_local_lab"
    },
    "authorized_public_program": {
      "target_patterns": [
        "must_match_scope_record"
      ],
      "tools": [
        "knowledge_search",
        "passive_recon_plan",
        "low_noise_active_profile_pending_runtime_implementation"
      ],
      "approval": "scope_record_plus_runtime_profile"
