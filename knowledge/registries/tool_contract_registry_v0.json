{
  "schema_version": "FATHIYA_TOOL_CONTRACT_REGISTRY_v0",
  "status": "draft",
  "purpose": "Registry of tool and adapter contracts governing side effects, inputs, outputs, receipts, and failure modes.",
  "contracts": [
    {
      "tool_id": "github_create_or_update_file",
      "name": "GitHub Create or Update File",
      "adapter": "Zapier GitHub",
      "queue": "Engineering Queue",
      "allowed_actions": ["create_file_on_branch", "update_file_on_branch"],
      "input_schema": ["repo", "branch", "path", "content", "commit_message"],
      "output_schema": ["commit_sha", "file_path", "html_url", "error"],
      "side_effects": ["git_commit"],
      "approval_required": true,
      "receipt_required": true,
      "failure_modes": ["repo_not_found", "branch_missing", "permission_denied", "content_too_large", "sha_conflict"],
      "status": "active"
    },
    {
      "tool_id": "cursor_launch_agent",
      "name": "Cursor Launch Agent",
      "adapter": "Zapier Cursor",
      "queue": "Engineering Queue",
      "allowed_actions": ["launch_agent_on_branch", "create_pr_if_enabled"],
      "input_schema": ["repository_url", "repository_ref", "target_branch_name", "prompt_text", "target_auto_create_pr"],
      "output_schema": ["agent_id", "status", "target_branch", "pr_url", "error"],
      "side_effects": ["agent_branch", "possible_pull_request"],
      "approval_required": true,
      "receipt_required": true,
      "failure_modes": ["agent_failed", "missing_artifact", "branch_conflict", "pr_not_created"],
      "status": "active"
    },
    {
      "tool_id": "manus_create_task",
      "name": "Manus Create Task",
      "adapter": "Zapier Manus",
      "queue": "Research Queue",
      "allowed_actions": ["create_research_task", "continue_task", "get_task"],
      "input_schema": ["task_prompt", "source_context", "expected_output"],
      "output_schema": ["task_id", "status", "result", "error"],
      "side_effects": ["research_task"],
      "approval_required": false,
      "receipt_required": true,
      "failure_modes": ["insufficient_context", "task_timeout", "ambiguous_prompt"],
      "status": "available"
    },
    {
      "tool_id": "n8n_workflow",
      "name": "n8n Workflow Activation",
      "adapter": "n8n",
      "queue": "Automation Queue",
      "allowed_actions": ["activate_workflow", "draft_workflow"],
      "input_schema": ["workflow_id", "trigger_data"],
      "output_schema": ["execution_id", "status", "result", "error"],
      "side_effects": ["workflow_execution", "possible_external_call"],
      "approval_required": true,
      "receipt_required": true,
      "failure_modes": ["workflow_not_found", "trigger_mismatch", "execution_timeout"],
      "status": "planned"
    },
    {
      "tool_id": "zapier_mcp_action",
      "name": "Zapier MCP Action",
      "adapter": "Zapier MCP",
      "queue": "Automation Queue",
      "allowed_actions": ["run_action", "list_tools"],
      "input_schema": ["action_id", "parameters"],
      "output_schema": ["result", "status", "error"],
      "side_effects": ["varies_by_action"],
      "approval_required": true,
      "receipt_required": true,
      "failure_modes": ["action_not_found", "auth_failure", "parameter_mismatch"],
      "status": "planned"
    },
    {
      "tool_id": "local_script_runner",
      "name": "Local Script Runner",
      "adapter": "local",
      "queue": "Engineering Queue",
      "allowed_actions": ["run_script", "validate_output"],
      "input_schema": ["script_path", "arguments"],
      "output_schema": ["exit_code", "stdout", "stderr"],
      "side_effects": ["local_file_changes"],
      "approval_required": false,
      "receipt_required": true,
      "failure_modes": ["script_not_found", "permission_denied", "timeout", "non_zero_exit"],
      "status": "planned"
    }
  ]
}